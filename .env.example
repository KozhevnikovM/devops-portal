# Optional: private PyPI mirror (e.g. Nexus, Artifactory)
# PIP_INDEX_URL=https://nexus.internal/repository/pypi/simple
# PIP_TRUSTED_HOST=nexus.internal

# Optional: private npm registry for frontend build stage
# NPM_CONFIG_REGISTRY=https://nexus.internal/repository/npm-proxy/

DATABASE_URL=postgresql+asyncpg://portal:portal@postgres:5432/portal
DATABASE_URL_SYNC=postgresql+psycopg2://portal:portal@postgres:5432/portal
REDIS_URL=redis://redis:6379/0
USE_STUB_TERRAFORM=true

# Auth
# ADMIN_USERNAME=admin          # username for the seeded admin account (default: admin)
# ADMIN_PASSWORD=changeme       # password for the seeded admin account — always override in production
# SESSION_TTL=86400             # browser session lifetime in seconds (default: 86400 = 24h)

# Celery provision task tuning
# PROVISION_MAX_RETRIES=3      # how many times to retry a failed provisioning task
# PROVISION_RETRY_DELAY=120    # seconds to wait between retries (match VCD token cooldown)
# PROVISION_RATE_LIMIT=0.5/m   # max tasks per worker per time window (0.5/m = 1 per 2 min)

# Terraform state backend (PostgreSQL)
# TF_PG_CONN_STR=postgresql://portal:portal@postgres:5432/portal?sslmode=disable  # standard postgres:// driver; add sslmode=disable for servers without SSL

# Terraform apply flags
# TF_APPLY_REFRESH=true       # pass -refresh=true/false to terraform apply (default true)
# TF_APPLY_PARALLELISM=1      # pass -parallelism=N; keep at 1 to avoid VCD API rate limits

# Real VCD adapter — only required when USE_STUB_TERRAFORM=false
# VCD_URL=https://vcd.example.com/api
# VCD_ORG=my-org
# VCD_VDC=my-vdc
# VCD_NETWORK_NAME=my-network
# VCD_ALLOW_UNVERIFIED_SSL=false
#
# VCD auth — option A: single API token
# VCD_API_TOKEN=your-refresh-token-here
#
# VCD auth — option A (token pool): comma-separated tokens for parallel provisioning
# VCD_API_TOKENS=token-a,token-b,token-c
# VCD_TOKEN_LOCK_TTL=900     # Redis lock TTL in seconds; auto-releases if worker crashes
# VCD_TOKEN_MAX_PARALLEL=4   # max concurrent provisioning jobs per token (default 4)
#
# VCD auth — option B: username/password (used when VCD_API_TOKEN/VCD_API_TOKENS are empty)
# VCD_USER=administrator
# VCD_PASSWORD=secret
