# Optional: private PyPI mirror (e.g. Nexus, Artifactory)
# PIP_INDEX_URL=https://nexus.internal/repository/pypi/simple
# PIP_TRUSTED_HOST=nexus.internal

# Optional: private npm registry for frontend build stage
# NPM_CONFIG_REGISTRY=https://nexus.internal/repository/npm-proxy/

DATABASE_URL=postgresql+asyncpg://portal:portal@postgres:5432/portal
DATABASE_URL_SYNC=postgresql+psycopg2://portal:portal@postgres:5432/portal
REDIS_URL=redis://redis:6379/0
USE_STUB_TERRAFORM=true
# PROVISION_MAX_RETRIES=3
# PROVISION_RETRY_DELAY=120
# PROVISION_RATE_LIMIT=0.5/m
DEV_USER_ID=dev-user-00000000

# Real VCD adapter — only required when USE_STUB_TERRAFORM=false
# VCD_URL=https://vcd.example.com/api
# VCD_ORG=my-org
# VCD_VDC=my-vdc
# VCD_VAPP_NAME=my-vapp
# VCD_NETWORK_NAME=my-network
# VCD_VAPP_TEMPLATE_ID=my-template-id-here
# VCD_ALLOW_UNVERIFIED_SSL=false
#
# VCD auth — option A: API token (preferred)
# VCD_API_TOKEN=your-refresh-token-here
#
# VCD auth — option B: username/password
# VCD_USER=administrator
# VCD_PASSWORD=secret
