# Optional: private PyPI mirror (e.g. Nexus, Artifactory)
# PIP_INDEX_URL=https://nexus.internal/repository/pypi/simple
# PIP_TRUSTED_HOST=nexus.internal

# Optional: local apt mirror for the image build (isolated/air-gapped). When APT_MIRROR is set the
# build replaces the base image's apt sources with the mirror (deb822, Trusted: yes) before
# installing OS packages. The mirror password (if any) is passed as a BuildKit *secret*
# (APT_REPO_PASSWORD), never a build arg/layer. Leave APT_MIRROR empty to use the default apt repos.
# APT_MIRROR=https://mirror.internal/debian
# APT_SECURITY_MIRROR=https://mirror.internal/debian-security
# APT_SUITE=bookworm                # base image suite (python:3.11-slim → bookworm)
# APT_COMPONENTS=main contrib
# APT_REPO_HOST=mirror.internal     # 'machine' for /etc/apt/auth.conf.d (only if the mirror needs auth)
# APT_REPO_USER=token               # 'login' for the auth entry (default: token)
# APT_REPO_PASSWORD=your-token      # keep out of source control; inject from CI / secret store

# Optional: private npm registry for the frontend build stage. NPM_REGISTRY sets the registry
# URL (a build arg). For an authenticated registry, set NPM_REGISTRY_TOKEN — Compose passes it to
# the build as a BuildKit *secret* (never a build arg/layer), and the build writes
# _authToken=base64("token:<token>") into a throwaway .npmrc. Leave both empty for public npm.
# NPM_REGISTRY=https://nexus.internal/repository/npm/
# NPM_REGISTRY_TOKEN=your-token   # keep out of source control; inject from CI / secret store
# NPM_CA_CERT_FILE=./npm-ca.crt   # PEM CA bundle if the registry uses an internal/self-signed CA

# Optional: base container images (full reference) for isolated / air-gapped environments.
# Each defaults to the pinned value below; override to pull from an internal registry mirror.
# PYTHON_IMAGE=registry.internal/python:3.11-slim
# NODE_IMAGE=registry.internal/node:20-slim
# TERRAFORM_IMAGE=registry.internal/hashicorp/terraform:1.9
# POSTGRES_IMAGE=registry.internal/postgres:15
# REDIS_IMAGE=registry.internal/redis:7

# Optional: UID/GID of the unprivileged runtime user baked into the image (build args).
# Set these to the host user that owns the bind-mounted code/volumes so file permissions line up.
# PORTAL_UID=1000
# PORTAL_GID=1000

# PostgreSQL credentials for the bundled `postgres` service (compose reads these from here).
# Default to portal/portal/portal; override in production and keep the password in a vault.
# If you change any of these, update the credentials/db name in DATABASE_URL(_SYNC) and
# TF_PG_CONN_STR below to match.
# POSTGRES_USER=portal
# POSTGRES_PASSWORD=portal
# POSTGRES_DB=portal

DATABASE_URL=postgresql+asyncpg://portal:portal@postgres:5432/portal
DATABASE_URL_SYNC=postgresql+psycopg2://portal:portal@postgres:5432/portal
REDIS_URL=redis://redis:6379/0
USE_STUB_TERRAFORM=true

# URL prefix when a reverse proxy forwards a subpath to the app *intact* (e.g. https://host/dp/
# without stripping). Makes FastAPI serve docs/static under that prefix. Empty = served at the
# root. Do NOT set this if the proxy already strips the prefix (trailing-slash proxy_pass) — that
# combination makes /static 404. See "Running behind an HTTPS reverse proxy" in the admin guide.
# ROOT_PATH=/dp

# Auth
# ADMIN_USERNAME=admin          # username for the seeded admin account (default: admin)
# ADMIN_PASSWORD=changeme       # password for the seeded admin account — always override in production
# SESSION_TTL=86400             # browser session lifetime in seconds (default: 86400 = 24h)
# SESSION_COOKIE_SECURE=true    # send the session cookie only over HTTPS (default: true).
                                #   Set false for local development over plain http://localhost.

# Celery provision task tuning
# PROVISION_MAX_RETRIES=3      # how many times to retry a failed provisioning task
# PROVISION_RETRY_DELAY=120    # seconds to wait between retries (match VCD token cooldown)
# PROVISION_RATE_LIMIT=0.5/m   # max tasks per worker per time window (0.5/m = 1 per 2 min)

# Celery beat tuning
# ENFORCE_TTL_INTERVAL_SECONDS=60   # how often to release expired bookings (default: 60s)

# Terraform state backend (PostgreSQL)
# TF_PG_CONN_STR=postgresql://portal:portal@postgres:5432/portal?sslmode=disable  # standard postgres:// driver; add sslmode=disable for servers without SSL

# Terraform apply flags
# TF_APPLY_REFRESH=true       # pass -refresh=true/false to terraform apply (default true)
# TF_APPLY_PARALLELISM=1      # pass -parallelism=N; keep at 1 to avoid VCD API rate limits

# Real VCD adapter — only required when USE_STUB_TERRAFORM=false
# VCD_URL=https://vcd.example.com/api
# VCD_ORG=my-org
# VCD_VDC=my-vdc
# VCD_NETWORK_NAME=my-network
# VCD_ALLOW_UNVERIFIED_SSL=false
#
# VCD auth — option A: single API token
# VCD_API_TOKEN=your-refresh-token-here
#
# VCD auth — option A (token pool): comma-separated tokens for parallel provisioning
# VCD_API_TOKENS=token-a,token-b,token-c
# VCD_TOKEN_LOCK_TTL=900     # Redis lock TTL in seconds; auto-releases if worker crashes
# VCD_TOKEN_MAX_PARALLEL=4   # max concurrent provisioning jobs per token (default 4)
#
# VCD auth — option B: username/password (used when VCD_API_TOKEN/VCD_API_TOKENS are empty)
# VCD_USER=administrator
# VCD_PASSWORD=secret

# Post-provision VM configuration — the worker SSHes into a provisioned VM to run a booking's
# startup_script (and, later, Ansible roles). Only used when USE_STUB_TERRAFORM=false.
# VM_SSH_USER=root              # SSH user present in the VM template
# VM_SSH_PORT=22
# VM_SSH_PRIVATE_KEY=           # PEM key path; empty → password auth with the generated VM password
# CONFIG_SSH_TIMEOUT=300        # seconds to wait for the VM's SSH to come up before failing (0 disables)
# CONFIG_SSH_RETRY_INTERVAL=30  # seconds between SSH connect attempts while waiting
# ANSIBLE_ROLES_PATH=/app/ansible/roles  # where the worker looks up Ansible roles applied to a VM
# ANSIBLE_TIMEOUT=1800          # seconds before an ansible-playbook run is killed
