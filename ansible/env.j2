# Managed by Ansible — do not edit by hand.
{% for key, value in portal_env.items() %}
{{ key }}={{ value }}
{% endfor %}
{% for key, value in (portal_images | default({})).items() %}
{{ key }}={{ value }}
{% endfor %}
{% if (npm_registry | default('')) | length > 0 %}
NPM_REGISTRY={{ npm_registry }}
{% endif %}
{% if (npm_registry_token | default('')) | length > 0 %}
NPM_REGISTRY_TOKEN={{ npm_registry_token }}
{% endif %}
{% if (npm_ca_cert | default('')) | length > 0 %}
NPM_CA_CERT_FILE={{ deploy_dir }}/npm-ca.crt
{% endif %}
